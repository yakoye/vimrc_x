" cscope {
    " such as: cursor -> AA()
    "
    " void BB();
    " void CC();
    " void AA() {
    "     BB();
    "     CC()
    " }
    " void foo() {
    "     AA()
    " }
    "   's'   symbol: find all references to the token KEYWORDS
    "   'g'   global: find global definition(s) of the token KEYWORDS
    "   'c'   calls:  find all calls to the function name KEYWORDS. ?,foo -> AA
    "   't'   text:   find all instances of the text KEYWORDS
    "   'e'   egrep:  egrep search for the word KEYWORDS
    "   'f'   file:   open the filename KEYWORDS
    "   'i'   includes: find files that include the filename KEYWORDS
    "   'd'   called: find functions that function KEYWORDS calls.  AA -> ?, ( BB, CC )
    
    " use KEYWORDS under cursor
    nmap <C-\>s :cs find s <C-R>=expand("<cword>")<CR><CR>
    nmap <C-\>g :cs find g <C-R>=expand("<cword>")<CR><CR>
    nmap <C-\>c :cs find c <C-R>=expand("<cword>")<CR><CR>
    nmap <C-\>t :cs find t <C-R>=expand("<cword>")<CR><CR>
    nmap <C-\>e :cs find e <C-R>=expand("<cword>")<CR><CR>
    nmap <C-\>f :cs find f <C-R>=expand("<cfile>")<CR><CR>
    nmap <C-\>i :cs find i ^<C-R>=expand("<cfile>")<CR>$<CR>
    nmap <C-\>d :cs find d <C-R>=expand("<cword>")<CR><CR>

