" 返回“模式名称”和“应该用的高亮组”
function! StatusMode() abort
    let l:m = mode(1)
    " 常见模式判定（覆盖 normal/insert/visual/replace/command 等）
    if l:m =~# '^n'
        return ['NORMAL', 'HLModeNormal']
    elseif l:m =~# '^i'
        return ['INSERT', 'HLModeInsert']
    elseif l:m =~# '^c'
        return ['COMMAND', 'HLModeCommand']
    elseif l:m =~# '^[vV\]'
        return ['VISUAL', 'HLModeVisual']
    elseif l:m =~# '^t'
        return ["TERMINAL", 'HLCModeTerminal']
    elseif l:m =~# '^R'
        return ['REPLACE', 'HLModeReplace']
    else
        return [toupper(l:m), 'HLModeOther']
    endif
endfunction

" 组装 statusline：左侧模式块变色 + 文件信息等
function! Statusline() abort
    let [l:name, l:hi] = StatusMode()

    " 左侧：模式块（变色）+ 文件名/选项
    let l:s  = '%#'.l:hi.'# '.l:name.' %*'                   " MODE (colored)

    " %#HLCFileName# : 切换到你定义的 HLCFileName 高亮组来显示文件名
    " %(...%)        : 分组（在 statusline 里用于组合一段内容）
    " %<             : 截断标记（窗口太窄时，从这里开始截断左侧内容）
    " %f             : 文件名（相对路径）
    let l:s .= '%#HLCFileName#%( %<%f%) '                    " Filename
    "   let l:s .= '%#HLCPath#%{getcwd()}/'                  " Current dir (可选)

    " %w : 预览窗口标记（[Preview] 之类；是 preview window 时显示）
    " %h : help buffer 标记（是 help 时显示）
    " %m : 修改标记（buffer 被修改过则显示 [+]）
    " %r : 只读标记（readonly 时显示 [RO]）
    " 这几个会根据状态自动出现/消失
    let l:s .= '%w%h%m%r'                                    " Options

    " 右侧
    let l:s .= '%= '                                         " 左右对齐分隔符
    
    " %#HLCFileType# : 使用 HLCFileType 高亮组
    " %y             : filetype（如 vim/lua/python；为空则显示空）
    " %{&ff}         : fileformat（&ff），如 unix/dos/mac
    " 两侧留空格是为了视觉分隔
    let l:s .= '%#HLCFileType# %y %{&ff} '                   " Filetype + fileformat

        " %#HLCLineNum#  : 使用 HLCLineNum 高亮组
    " %(...%)        : 分组
    " %l             : 当前行号（line）
    " %c             : 当前列号（column）
    " %V             : 虚拟列号（virtual column；用于 tab/全角等场景）
    " %p%%           : 当前光标在文件中的百分比（%% 是字面量 %）
    " 你这里用字面量 '=' 做分隔：' = '
    " let l:s .= '%#HLCLineNum# %(%l,%c%V%) = %p%% '        " Line/Col + percent
    let l:s .= '%#'.l:hi.'# '.'%(%l,%c%V%) = %p%% '        " Line/Col + percent

    return l:s
endfunction

