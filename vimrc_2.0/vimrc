function! LoadThemeConfig()
    " syn match cFunctionmy "\<\h\w*\ze\_s*("
    syn match cFunctionmy "\<\%(defined\|sizeof\|typeof\)\@!\h\w*\ze\_s*("
    highlight cFunctionmy guifg=#a6e23e cterm=bold  ctermfg=37
    
    syn match cFunctionPointermy "\%((\s*\*\s*\)\@<=\h\w*\ze\s*)\_s*(.*)"
    highlight cFunctionPointermy guifg=#d7ff00 cterm=bold  ctermfg=76

    syntax match MyOperator "+\|\-\|=\|%\|:\|?\|!\|<\|>\||\|&\|\^\|\~\|\$"
    syntax match MyOperator "\*\ze[^/]"   " * 后面不是 /
    syntax match MyOperator "\%([^/]\)\zs\*"  " 前面不是 /
    syntax match MyOperator "\%([^*]\)\zs/\ze\%([^*/]\)"  "匹配/
    highlight MyOperator ctermfg=206 guifg=#ff5fd7

    syntax match MyOperator2 "\.\ze[A-Za-z_]"  "匹配.
    syntax match MyOperator2 "->"  "匹配.
    " highlight MyOperator2 ctermfg=246 guifg=#949494
    highlight MyOperator2 ctermfg=086 guifg=#5fffd7
