function! ConfigNerdtree()
    let NERDTreeShowBookmarks=1
    let NERDTreeChDirMode=0
    let NERDTreeQuitOnOpen=0
    let NERDTreeMouseMode=2
    let NERDTreeShowHidden=1
    let NERDTreeKeepTreeInNewTab=1
    let NERDTreeAutoCenter=1
    let NERDTreeAutoCenterThreshold=3
    let g:nerdtree_tabs_open_on_gui_startup=0
    let g:nerdtree_tabs_open_on_console_startup=0
    let g:nerdtree_tabs_smart_startup_focus=2
    let g:nerdtree_tabs_on_new_tab=1
    let g:nerdtree_tabs_autoclose=0
    let NERDTreeIgnore=['\.py[cd]$', '\~$', '\.swo$', '\.swp$',
                        \ '^\.git$', '^\.hg$', '^\.svn$', '\.bzr$',
                        \ '^cscope\.*', '^tags$']
    
    " function! NERDTreeToggleOrFind()
    "     if exists("t:NERDTreeBufName") && bufwinnr(t:NERDTreeBufName) != -1
    "         NERDTreeToggle
    "     else
    "         if expand('%') != ''
    "             NERDTreeFind
    "         else
    "             NERDTreeToggle
    "         endif
    "     endif
    " endfunction

    function! NERDTreeToggleAndFind() abort
        " 如果当前就在 NERDTree，先回到上一个窗口，避免 Toggle 关错窗口
        if &filetype ==# 'nerdtree'
            wincmd p
        endif

        let l:curwin = win_getid()

        if exists("t:NERDTreeBufName") && bufwinnr(t:NERDTreeBufName) != -1
            silent! NERDTreeToggle
        else
            if expand('%:p') !=# '' && &buftype ==# ''
                silent! NERDTreeFind
            else
                silent! NERDTreeToggle
            endif
        endif

        " 把焦点拉回编辑窗口
        call win_gotoid(l:curwin)
    endfunction

    function! NERDTreeOpenAndFind() abort
        " 在 NERDTree 窗口里按也没事：先回到编辑窗口
        if &filetype ==# 'nerdtree'
            wincmd p
        endif

        " 没有当前文件就只打开树
        if expand('%:p') ==# '' || &buftype !=# ''
            silent! NERDTree
            return
        endif

        " 判断 NERDTree 窗口是否存在
        let l:tree_visible = exists('t:NERDTreeBufName') && bufwinnr(t:NERDTreeBufName) != -1

        " 无论树是否存在，都定位到当前文件：
        " - 不存在时，NERDTreeFind 会自动打开树并定位
        " - 存在时，NERDTreeFind 只会定位
        silent! NERDTreeFind
    endfunction

    nnoremap <C-e> :call NERDTreeToggleAndFind()<CR>
    nnoremap <leader>e :call NERDTreeOpenAndFind()<CR>

    " map <C-e> :NERDTreeToggle<CR>
    "map <leader>e :NERDTreeFind<CR>
    "nmap <leader>nt :NERDTreeFind<CR>

    let s:last_bufnr = -1

    function! s:NERDTreeSyncOnBufChange() abort
        " 点到 NERDTree 时不要触发，否则必然抢焦点乱跳
        if &filetype ==# 'nerdtree' | return | endif
        if &filetype =~# '^LeaderF' | return | endif
        
        " LeaderF 预览/内部 buffer：/Lf_preview_xxx
        if bufname('%') =~# 'Lf_preview_' | return | endif
        if bufname('%') =~# '^LeaderF://' | return | endif

        " 只对真实文件生效（LeaderF 预览这种通常不是可读文件）
        let l:path = expand('%:p')
        if l:path ==# '' || !filereadable(l:path) | return | endif

        if !exists('t:NERDTreeBufName') || bufwinnr(t:NERDTreeBufName) == -1 | return | endif
        let l:bn = bufnr('%')
        if l:bn == s:last_bufnr | return | endif
        let s:last_bufnr = l:bn

        let l:curwin = win_getid()
        let l:save_cwd = getcwd()

        try
            if exists('*g:NERDTreeDirNodeGetRoot')
                let l:root = g:NERDTreeDirNodeGetRoot()
                if type(l:root) == type({}) && has_key(l:root, 'path')
                    execute 'lcd' fnameescape(l:root.path.str())
                endif
            endif

            silent! NERDTreeFind
        finally
            execute 'lcd' fnameescape(l:save_cwd)
            call win_gotoid(l:curwin)
        endtry

        " 居中当前文件所在行（避免显示在顶端）
        silent! normal! zz
    endfunction

    augroup NerdTreeSync
        autocmd!
        autocmd BufEnter * call <SID>NERDTreeSyncOnBufChange()
    augroup END


endfunction

