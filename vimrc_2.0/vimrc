function! ShowTagsSourcePopup()
    let l:word = expand('<cword>')
    let l:tags = taglist(l:word)
    " echom l:tags
    if empty(l:tags)
        echo "No tags found for " . l:word
        return
    endif

    let l:items = []
    for l:tag in l:tags
        let l:file = l:tag.filename
        let l:line = str2nr(get(l:tag, 'line', '0'))
        let l:src_line = '[No source line]'

        " 有行号的情况直接读那一行
        if filereadable(l:file) && l:line > 0
            let l:src_list = getbufline(bufadd(l:file), l:line)
            if !empty(l:src_list)
                let l:src_line = substitute(l:src_list[0], '^\s*\|\s*$', '', 'g')
            endif
        " 没行号但有 cmd=搜索模式 的情况
        elseif has_key(l:tag, 'cmd') && l:tag.cmd =~ '^/'
            let l:pattern = matchstr(l:tag.cmd, '^/\(.*\)/$')
            for line_text in readfile(l:file)
                if line_text =~ l:pattern
                    let l:src_line = substitute(line_text, '^\s*\|\s*$', '', 'g')
                    break
                endif
            endfor
        endif

        call add(l:items, printf("%s [%s:%d]",
                    \ l:src_line, fnamemodify(l:file, ':t'), l:line))
    endfor

    highlight MyPopup guibg=#5f00ff guifg=#ffffff  " 内容区域：深背景+白字
    " 在光标位置正上方弹出选择菜单
    " let choice = popup_atcursor(l:items, #{title: l:word, pos: 'botleft', maxheight: 10})
    let choice = popup_atcursor(l:items, #{pos: 'botleft', maxheight: 10, highlight: 'MyPopup'})

    " 回车选择后跳转
    if choice >= 1 && choice <= len(l:tags)
        execute 'edit +' . l:tags[choice - 1].line . ' ' . l:tags[choice - 1].filename
    endif
endfunction

" <silent> 避免状态栏显示调用命令
nnoremap <silent> <leader>] :call ShowTagsSourcePopup()<CR>



function! ToggleComment()
    let l:ft = &filetype
    let l:line = getline('.')
    if l:ft =~? '^\(c\|cpp\|h\|hpp\)$'
        let l:comment = '//'
    elseif l:ft =~? '^\(sh\|zsh\|shell\|bash\)$' || l:ft ==# 'python' || l:ft ==# 'make'
        let l:comment = '#'
    elseif l:ft ==# 'vim'
        let l:comment = '"'
    elseif l:ft ==# 'lua'
        let l:comment = '--'
    else
        let l:comment = '#'
    endif

    if l:line =~# '^\s*' . escape(l:comment, '#/\"')
        call setline('.', substitute(l:line, '^\(\s*\)' . escape(l:comment, '#/\"') . '\s\?', '\1', ''))
    else
        call setline('.', substitute(l:line, '^\s*', '\0' . l:comment . ' ', ''))
    endif
endfunction

function! ToggleCommentVisual()
    let l:start = line("'<")
    let l:end = line("'>")
    let l:ft = &filetype
    if l:ft =~? '^\(c\|cpp\|h\|hpp\)$'
        let l:comment = '//'
    elseif l:ft =~? '^\(sh\|zsh\|shell\|bash\)$' || l:ft ==# 'python' || l:ft ==# 'make'
        let l:comment = '#'
    elseif l:ft ==# 'vim'
        let l:comment = '"'
    elseif l:ft ==# 'lua'
        let l:comment = '--'
    else
        let l:comment = '#'
    endif
    let uncomment = 1
    for lnum in range(l:start, l:end)
        if getline(lnum) !~# '^\s*' . escape(l:comment, '#/\"')
            let uncomment = 0
            break
        endif
    endfor
    for lnum in range(l:start, l:end)
        let l:line = getline(lnum)
        if uncomment
            call setline(lnum, substitute(l:line, '^\(\s*\)' . escape(l:comment, '#/\"') . '\s\?', '\1', ''))
        else
            call setline(lnum, substitute(l:line, '^\s*', '\0' . l:comment . ' ', ''))
        endif
    endfor
endfunction

