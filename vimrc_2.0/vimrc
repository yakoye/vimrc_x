function! MyBufferLine()
    let s = ''
    for i in range(1, bufnr('$'))
        " if buflisted(i)
        if buflisted(i) && (bufloaded(i) || i == bufnr('%'))
            " 获取文件名或 [No Name]
            let name = bufname(i)
            if empty(name)
                let buffername = i . ':[No Name]'
            else
                let buffername = i . ':' . fnamemodify(name, ':t')
            endif

            " 如果已修改，加 * 标记
            if getbufvar(i, '&modified')
                let buffername .= '*'
            endif

            " 如果是只读文件，加 [RO] 标记
            if getbufvar(i, '&readonly')
                let buffername .= '[RO]'
            endif

            " echom 'Current Buffer: ' . i  bufnr('%')
            " 当前 buffer 高亮
            if i == bufnr('%')
                let s .= '%' . i . 'T' . '%#TabLineSel#' . ' ' . buffername . ' ' . '%#TabLine#'
            else
                let s .= '%' . i . 'T' . '%#TabLine#' . ' ' . buffername . ' ' . '%#TabLine#'
            endif
        endif
    endfor
    return s
endfunction
