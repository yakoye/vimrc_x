function! DeleteCurrentAndGoPrevBuffer()
    let l:current = bufnr('%')
    let l:prev = GetPrevBuffer()
    if l:prev > 0 && l:prev != l:current
        execute 'buffer ' . l:prev
    endif
    execute 'bdelete ' . l:current
endfunction

function! GetPrevBuffer()
    let buflist = filter(range(1, bufnr('$')), 'buflisted(v:val)')
    let current = bufnr('%')
    let idx = index(buflist, current)
    if idx > 0
        return buflist[idx - 1]
    endif
    return -1
endfunction

" 快捷键：关闭当前 buffer
