" ==== terminal-help ====
function! LoadTerminalhelp()
    call ConfigTerminalhelp()
endfunction

function! ConfigTerminalhelp()
    " 在这里配置 terminal-help

    function! s:TermToggleOrOpen() abort
            " 1) 先在现有 buffer 里找 terminal
            for b in range(1, bufnr('$'))
                if bufexists(b) && getbufvar(b, '&buftype') ==# 'terminal'
                " 已有 terminal：用 split 打开它
                execute 'botright sbuffer' b
                return
            endif
        endfor
        " 2) 没找到：新建一个 terminal（下方分屏）
        terminal
    endfunction

    nnoremap <leader>= :call <SID>TermToggleOrOpen()<CR>

    augroup TermKey
        autocmd!
        " nnoremap <leader>= :botright split \| terminal<CR>
        " nnoremap <leader>= :call <SID>TermToggleOrOpen()<CR>

        " Alt-- 关闭窗口，不关闭buffer（相当于 :hide）, :sb 2 回到终端输入
        autocmd TerminalWinOpen * tnoremap <buffer> <leader>0 <C-\><C-n>
        autocmd TerminalWinOpen * tnoremap <buffer> <leader>- <C-\><C-n>:hide<CR>
        autocmd TerminalWinOpen * nnoremap <buffer> <leader>- :hide<CR>

        " Alt-q 关闭窗口，关闭buffer
        autocmd TerminalWinOpen * tnoremap <buffer> <leader>q <C-\><C-n>:bd!<CR>
        autocmd TerminalWinOpen * nnoremap <buffer> <leader>q :bd!<CR>
    augroup END
endfunction

