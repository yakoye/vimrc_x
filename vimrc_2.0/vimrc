" 设置自动补全
" let g:completion_trigger_length = 1
function! s:smart_complete()
    " Get the current column number, adjusting for zero-based index
    let l:col = col('.') - 1
    " Get the content of the current line up to the current column position
    let l:line = getline('.')[0 : l:col-1]

    " Debug: Uncomment the line below to print the current word being analyzed
    " echom 'Current Word: ' . matchstr(l:line, '\v\w+$')
  
    " Check for an empty line or a whitespace character just before the
    " cursor
    if l:line =~ '^\s*$' || l:line[-1:] =~ '\s'
        if pumvisible() | call feedkeys("\<C-E>") | endif
        return
    endif

    " Extract the current word from the input line based on alphanumeric
    " characters
    let l:current_word = matchstr(l:line, '\v\w+$')
    " Trigger completion if the current word length is greater than or equal
    " to the threshold and the completion menu is not visible
    if len(l:current_word) > g:completion_trigger_length && !pumvisible()
        call feedkeys("\<C-N>", 'n')
    endif
endfunction

