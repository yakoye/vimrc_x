function! CheckVimMode()
    let l:mode = mode()
    if l:mode ==# 'n'
        return "NORMAL"
    elseif l:mode ==# 'i'
        return "INSERT"
    elseif l:mode ==# 'v'
        return "VISUAL"
    elseif l:mode ==# 'V'
        return "V-LINE"
    elseif l:mode ==# "\<C-v>"
        return "V-BLOCK"
    elseif l:mode ==# 'c'
        return "COMMAND"
    elseif l:mode ==# 'R'
        return "REPLACE"
    elseif l:mode ==# 'R'
        return "REPLACE"
    else
        return l:mode
    endif
endfunction

" Configure the status bar
