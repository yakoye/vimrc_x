    set statusline=%#HLCMode#
    set statusline+=\ %{CheckVimMode()}               " 显示当前模式
    set statusline+=\ %#HLCFileName#%(\ %<%f%)          " Filename
    "set statusline+=\ %#HLCPath#%{getcwd()}/          " Current dir
    "set statusline=%<%f\                             " Filename
    set statusline+=\ %w%h%m%r                        " Options
    set statusline+=\ %=%#HLCFileType#%y\ %{&ff}           " Filetype
    set statusline+=\ %#HLCLineNum#%(%l,%c%V%)\ \=\ %p%%  " Right aligned file nav info
endif

" Reopen the last edited position in files
function! ResCur()
    if line("'\"") <= line("$")
        silent! normal! g`"
        return 1
    endif
endfunction

augroup resCur
    autocmd!
    autocmd BufWinEnter * call ResCur()
augroup END

