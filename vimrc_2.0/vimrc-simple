" 增强版左侧切换函数
function! ToggleNetrwLeft()
    let l:origin_win = winnr()
    let l:curfile = expand('%:p')
    let l:curfilename = expand('%:t')
    let l:curdir = expand('%:p:h')
    " 查找已存在netrw窗口
    let l:netrw_winlist = filter(range(1, winnr('$')), 'getwinvar(v:val, "&filetype") ==# "netrw"')
    if !empty(l:netrw_winlist)
        " 目录已开，关闭之
        execute l:netrw_winlist[0] . "wincmd w"
        close
        if l:origin_win <= winnr('$')
            execute l:origin_win . "wincmd w"
        else
            execute winnr('$') . "wincmd w"
        endif
    else
        " 跳到当前文件目录并开启netrw
        execute 'silent! Lexplore! ' . fnameescape(l:curdir)
        " 保证netrw在最左
        wincmd H
        vert resize 30
        setlocal winfixwidth
        setlocal nonumber norelativenumber
        setlocal signcolumn=no
        setlocal cursorline
        nnoremap <buffer> <silent> q :close<CR>
        " 自动切到右侧文件(主窗口)
        augroup MyNetrwSwitch
            autocmd!
            autocmd BufLeave <buffer> if &filetype ==# 'netrw' && winnr('$') > 1 | wincmd l | endif
        augroup END
        " --- 自动选中文件, 类似NERDTreeFind ---
        " 延迟一点确保 netrw 列表生成完毕
        call timer_start(30, {-> execute('call search(' . string(l:curfilename) . ', "w")')}, {'repeat': 1})
    endif
endfunction
nnoremap <silent> <leader>e :call ToggleNetrwLeft()<CR>


function! JumpToFunctionList()
    if &filetype ==# 'c' || &filetype ==# 'cpp' || &filetype ==# 'h' || &filetype ==# 'hpp'
        let pattern = '^\s*\(void\|char\|int\|float\|double\|static\|bool\|unsigned\|long\|short\|struct\)\s\+\(\w\+\s*\*\s*\)*\w\+\s*('
    elseif &filetype ==# 'python'
        let pattern = '^\s*def\s\+\w\+\s*('
    elseif &filetype ==# 'javascript'
        let pattern = '^\s*function\s\+\w\+\s*('
    elseif &filetype ==# 'java'
        let pattern = '^\s*\(public\|private\|protected\)\?\s*\w\+\s\+\w\+\s*('
    else
        let pattern = '.*'
    endif

    cclose
    silent! execute 'vimgrep/' . pattern . '/ %'
    if len(getqflist()) > 0
        copen
    else
        echo "No function definitions found."
    endif
endfunction
nnoremap <silent> <leader>t :call JumpToFunctionList()<CR>

function! ToggleComment()
    let l:ft = &filetype
    let l:line = getline('.')
    if l:ft =~? '^\(c\|cpp\|h\|hpp\)$'
        let l:comment = '//'
    elseif l:ft =~? '^\(sh\|zsh\|shell\|bash\)$' || l:ft ==# 'python' || l:ft ==# 'make'
        let l:comment = '#'
    elseif l:ft ==# 'vim'
        let l:comment = '"'
    elseif l:ft ==# 'lua'
        let l:comment = '--'
    else
        let l:comment = '#'
    endif

    if l:line =~# '^\s*' . escape(l:comment, '#/\"')
        call setline('.', substitute(l:line, '^\(\s*\)' . escape(l:comment, '#/\"') . '\s\?', '\1', ''))
    else
        call setline('.', substitute(l:line, '^\s*', '\0' . l:comment . ' ', ''))
    endif
endfunction

function! ToggleCommentVisual()
    let l:start = line("'<")
    let l:end = line("'>")
    let l:ft = &filetype
    if l:ft =~? '^\(c\|cpp\|h\|hpp\)$'
        let l:comment = '//'
    elseif l:ft =~? '^\(sh\|zsh\|shell\|bash\)$' || l:ft ==# 'python' || l:ft ==# 'make'
        let l:comment = '#'
    elseif l:ft ==# 'vim'
        let l:comment = '"'
    elseif l:ft ==# 'lua'
        let l:comment = '--'
    else
        let l:comment = '#'
    endif
    let uncomment = 1
    for lnum in range(l:start, l:end)
        if getline(lnum) !~# '^\s*' . escape(l:comment, '#/\"')
            let uncomment = 0
            break
        endif
    endfor
    for lnum in range(l:start, l:end)
        let l:line = getline(lnum)
        if uncomment
            call setline(lnum, substitute(l:line, '^\(\s*\)' . escape(l:comment, '#/\"') . '\s\?', '\1', ''))
        else
            call setline(lnum, substitute(l:line, '^\s*', '\0' . l:comment . ' ', ''))
        endif
    endfor
endfunction

" 单行快捷键
nnoremap <silent> <leader>c :call ToggleComment()<CR>
" 可视块/多行快捷键
vnoremap <silent> <leader>c :<C-u>call ToggleCommentVisual()<CR>


